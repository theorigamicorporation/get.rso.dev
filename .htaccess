DirectoryIndex index.html

RewriteEngine On

# Force index.html over index.php
RewriteRule ^index\.php$ /index.html [L,R=301]

# Redirect old /sh/<name> URLs to /<name> (backwards compat)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^sh/(.+)$ /$1 [R=301,L]

# Serve shell scripts from sh/ directory without /sh/ in the URL
# e.g. /get-jq → sh/get-jq.sh
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{DOCUMENT_ROOT}/sh/%{REQUEST_URI}.sh -f
RewriteRule ^(.+)$ sh/$1.sh [L]

# Remove .ps1 extension for clean URLs (keep /ps/ prefix)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.ps1 -f
RewriteRule ^(.+)$ $1.ps1 [L]

# Serve scripts as plain text
<FilesMatch "\.(sh|ps1)$">
    Header set Content-Type "text/plain; charset=UTF-8"
</FilesMatch>

# Prevent browser caching of HTML and MD (always fetch fresh)
<FilesMatch "\.(html|md)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
</FilesMatch>
